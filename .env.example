# Lightline Node — Environment Variables
# Copy this file to .env and fill in the values
#
# Setup: https://github.com/Lightline-Panel/lightline-node
# Follows Marzban-node pattern: certificate-based mTLS authentication

# ===== Service =====
# Port for the node REST API (panel connects to this)
SERVICE_PORT=62050
SERVICE_HOST=0.0.0.0

# ===== Shadowsocks =====
# Port for the Shadowsocks server (clients connect to this)
SS_PORT=8388

# Path to shadowsocks config file (auto-managed by the node)
SS_CONFIG_PATH=/etc/shadowsocks/config.json

# ===== TLS / mTLS =====
# Node auto-generates its own SSL cert/key on first run.
# To enable mTLS (recommended), copy the panel's certificate here:
SSL_CLIENT_CERT_FILE=/var/lib/lightline-node/ssl_client_cert.pem

# Node's own SSL cert/key (auto-generated if missing)
SSL_CERT_FILE=/var/lib/lightline-node/ssl_cert.pem
SSL_KEY_FILE=/var/lib/lightline-node/ssl_key.pem

# ===== Debug =====
# DEBUG=false
