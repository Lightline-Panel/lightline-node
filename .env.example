# Lightline Node — Environment Variables
# Copy this file to .env and fill in the values

# ===== Node Agent =====
# Port for the node agent REST API (panel communicates with this)
NODE_PORT=9090
NODE_HOST=0.0.0.0

# Authentication token (must match what's configured in the panel)
NODE_TOKEN=your-secret-node-token-here

# ===== Shadowsocks =====
# Port for the Shadowsocks server (clients connect to this)
SS_PORT=8388

# Path to shadowsocks config file (auto-managed by the node)
SS_CONFIG_PATH=/etc/shadowsocks/config.json

# ===== TLS (for node agent API) =====
SSL_CERT_FILE=/var/lib/lightline-node/cert.pem
SSL_KEY_FILE=/var/lib/lightline-node/key.pem
