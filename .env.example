# Lightline Node — Environment Variables
# Copy this file to .env and fill in the values

# Node agent port
NODE_PORT=9090
NODE_HOST=0.0.0.0

# Authentication token — must match the token configured in the panel when adding this node
NODE_TOKEN=change-me-to-a-random-token

# Outline Server Management API URL
# Find this in /opt/outline/access.txt or Outline Manager
# Example: https://127.0.0.1:12345/AbCdEfGh
OUTLINE_API_URL=
OUTLINE_API_KEY=

# TLS certificates (optional — generated automatically if not provided)
SSL_CERT_FILE=/var/lib/lightline-node/cert.pem
SSL_KEY_FILE=/var/lib/lightline-node/key.pem
